@article{sanchis-segura_effects_2020,
	title = {Effects of different intracranial volume correction methods on univariate sex differences in grey matter volume and multivariate sex prediction},
	volume = {10},
	copyright = {2020 The Author(s)},
	issn = {2045-2322},
	url = {https://www.nature.com/articles/s41598-020-69361-9},
	doi = {10.1038/s41598-020-69361-9},
	abstract = {Sex differences in 116 local gray matter volumes (GMVOL) were assessed in 444 males and 444 females without correcting for total intracranial volume (TIV) or after adjusting the data with the scaling, proportions, power-corrected proportions (PCP), and residuals methods. The results confirmed that only the residuals and PCP methods completely eliminate TIV-variation and result in sex-differences that are “small” (∣d∣ {\textless} 0.3). Moreover, as assessed using a totally independent sample, sex differences in PCP and residuals adjusted-data showed higher replicability (\$\${\textbackslash}approx \$\$93\%) than scaling and proportions adjusted-data \$\$( {\textbackslash}approx \$\$68\%) or raw data (\$\${\textbackslash}approx \$\$45\%). The replicated effects were meta-analyzed together and confirmed that, when TIV-variation is adequately controlled, volumetric sex differences become “small” (∣d∣ {\textless} 0.3 in all cases). Finally, we assessed the utility of TIV-corrected/ TIV-uncorrected GMVOL features in predicting individuals’ sex with 12 different machine learning classifiers. Sex could be reliably predicted ({\textgreater} 80\%) when using raw local GMVOL, but also when using scaling or proportions adjusted-data or TIV as a single predictor. Conversely, after properly controlling TIV variation with the PCP and residuals’ methods, prediction accuracy dropped to \$\${\textbackslash}approx \$\$60\%. It is concluded that gross morphological differences account for most of the univariate and multivariate sex differences in GMVOL},
	language = {en},
	number = {1},
	urldate = {2026-01-29},
	journal = {Sci Rep},
	author = {Sanchis-Segura, Carla and Ibañez-Gual, Maria Victoria and Aguirre, Naiara and Cruz-Gómez, Álvaro Javier and Forn, Cristina},
	month = jul,
	year = {2020},
	note = {Publisher: Nature Publishing Group},
	keywords = {Brain, Sexual dimorphism},
	pages = {12953},
	file = {Full Text PDF:files/2953/Sanchis-Segura et al. - 2020 - Effects of different intracranial volume correction methods on univariate sex differences in grey ma.pdf:application/pdf},
}

