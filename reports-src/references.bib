	title = {Multimodal population brain imaging in the {UK} {Biobank} prospective epidemiological study},
	volume = {19},
	issn = {1097-6256},
	url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC5086094/},
	doi = {10.1038/nn.4393},
	abstract = {Medical imaging has enormous potential for early disease prediction, but is impeded by the difficulty and expense of acquiring datasets prior to symptom onset. UK Biobank aims to address this problem directly by acquiring high quality, consistently acquired imaging data from 100,000 predominantly healthy participants, with health outcomes tracked over coming decades. The brain imaging includes structural, diffusion and functional modalities. Along with body and cardiac imaging, genetics, lifestyle measures, biological phenotyping and health records, this is expected to enable discovery of imaging markers of a broad range of diseases at their earliest stages, as well as provide unique insight into disease mechanisms. We describe UK Biobank brain imaging, and present results derived from the first 5,000 participants’ data release. Although that covers just 5\% of the ultimate cohort, it already yields a rich range of associations between brain imaging and other measures collected by UK Biobank.},
	number = {11},
	urldate = {2026-01-28},
	journal = {Nat Neurosci},
	author = {Miller, Karla L and Alfaro-Almagro, Fidel and Bangerter, Neal K and Thomas, David L and Yacoub, Essa and Xu, Junqian and Bartsch, Andreas J and Jbabdi, Saad and Sotiropoulos, Stamatios N and Andersson, Jesper LR and Griffanti, Ludovica and Douaud, Gwenaëlle and Okell, Thomas W and Weale, Peter and Dragonu, Iulius and Garratt, Steve and Hudson, Sarah and Collins, Rory and Jenkinson, Mark and Matthews, Paul M and Smith, Stephen M},
	month = nov,
	year = {2016},
	pmid = {27643430},
	pmcid = {PMC5086094},
	pages = {1523--1536},
	file = {Full Text PDF:files/2935/Miller et al. - 2016 - Multimodal population brain imaging in the UK Biobank prospective epidemiological study.pdf:application/pdf},
}

@article{obrien_statistical_2011,
	title = {Statistical adjustments for brain size in volumetric neuroimaging studies: {Some} practical implications in methods},
	volume = {193},
	issn = {0925-4927},
	shorttitle = {Statistical adjustments for brain size in volumetric neuroimaging studies},
	url = {https://www.sciencedirect.com/science/article/pii/S0925492711000357},
	doi = {10.1016/j.pscychresns.2011.01.007},
	abstract = {Volumetric magnetic resonance imaging (MRI) brain data provide a valuable tool for detecting structural differences associated with various neurological and psychiatric disorders. Analysis of such data, however, is not always straightforward, and complications can arise when trying to determine which brain structures are “smaller” or “larger” in light of the high degree of individual variability across the population. Several statistical methods for adjusting for individual differences in overall cranial or brain size have been used in the literature, but critical differences exist between them. Using agreement among those methods as an indication of stronger support of a hypothesis is dangerous given that each requires a different set of assumptions be met. Here we examine the theoretical underpinnings of three of these adjustment methods (proportion, residual, and analysis of covariance) and apply them to a volumetric MRI data set. These three methods used for adjusting for brain size are specific cases of a generalized approach which we propose as a recommended modeling strategy. We assess the level of agreement among methods and provide graphical tools to assist researchers in determining how they differ in the types of relationships they can unmask, and provide a useful method by which researchers may tease out important relationships in volumetric MRI data. We conclude with the recommended procedure involving the use of graphical analyses to help uncover potential relationships the ROI volumes may have with head size and give a generalized modeling strategy by which researchers can make such adjustments that include as special cases the three commonly employed methods mentioned above.},
	number = {2},
	urldate = {2026-01-28},
	journal = {Psychiatry Research: Neuroimaging},
	author = {O'Brien, Liam M. and Ziegler, David A. and Deutsch, Curtis K. and Frazier, Jean A. and Herbert, Martha R. and Locascio, Joseph J.},
	month = aug,
	year = {2011},
	keywords = {Morphometry, MRI, Regression models, Statistics},
	pages = {113--122},
	file = {ScienceDirect Full Text PDF:files/2938/O'Brien et al. - 2011 - Statistical adjustments for brain size in volumetric neuroimaging studies Some practical implicatio.pdf:application/pdf;ScienceDirect Snapshot:files/2937/S0925492711000357.html:text/html},
}

@article{yuan_measurement_2016,
	title = {Measurement invariance via multigroup {SEM}: {Issues} and solutions with chi-square-difference tests},
	volume = {21},
	issn = {1939-1463},
	shorttitle = {Measurement invariance via multigroup {SEM}},
	doi = {10.1037/met0000080},
	abstract = {Multigroup structural equation modeling (SEM) plays a key role in studying measurement invariance and in group comparison. When population covariance matrices are deemed not equal across groups, the next step to substantiate measurement invariance is to see whether the sample covariance matrices in all the groups can be adequately fitted by the same factor model, called configural invariance. After configural invariance is established, cross-group equalities of factor loadings, error variances, and factor variances-covariances are then examined in sequence. With mean structures, cross-group equalities of intercepts and factor means are also examined. The established rule is that if the statistic at the current model is not significant at the level of .05, one then moves on to testing the next more restricted model using a chi-square-difference statistic. This article argues that such an established rule is unable to control either Type I or Type II errors. Analysis, an example, and Monte Carlo results show why and how chi-square-difference tests are easily misused. The fundamental issue is that chi-square-difference tests are developed under the assumption that the base model is sufficiently close to the population, and a nonsignificant chi-square statistic tells little about how good the model is. To overcome this issue, this article further proposes that null hypothesis testing in multigroup SEM be replaced by equivalence testing, which allows researchers to effectively control the size of misspecification before moving on to testing a more restricted model. R code is also provided to facilitate the applications of equivalence testing for multigroup SEM. (PsycINFO Database Record},
	language = {eng},
	number = {3},
	journal = {Psychol Methods},
	author = {Yuan, Ke-Hai and Chan, Wai},
	month = sep,
	year = {2016},
	pmid = {27266799},
	keywords = {Analysis of Variance, Chi-Square Distribution, Humans, Models, Statistical, Monte Carlo Method, Research Design},
	pages = {405--426},
	file = {PDF:files/2941/Yuan and Chan - 2016 - Measurement invariance via multigroup SEM Issues and solutions with chi-square-difference tests.pdf:application/pdf},
}

@article{nordenskjold_intracranial_2015,
	title = {Intracranial volume normalization methods: considerations when investigating gender differences in regional brain volume},
	volume = {231},
	issn = {0925-4927},
	doi = {10.1016/j.pscychresns.2014.11.011},
	abstract = {Intracranial volume (ICV) is commonly used for normalization of regional brain volumes in morphometric studies. Several methods for ICV-correction have been proposed, but there is little consensus regarding which method to use in different applications. The method used may have a considerable impact on the results, especially when investigating regional volume differences between males and females. In this study, we evaluated six different ICV-normalization methods and their effects on regional volume differences between sexes in a sample of healthy adults. We found that the choice of normalization method had a substantial impact on the results, with some methods showing significant sex differences while others did not. We provide guidelines for choosing appropriate normalization methods based on the research question and discuss the implications for studies of sexual dimorphism in brain structure.},
	language = {eng},
	number = {3},
	journal = {Psychiatry Research: Neuroimaging},
	author = {Nordenskjöld, Richard and Malmberg, Filip and Larsson, Elna-Marie and Simmons, Andrew and Ahlström, Håkan and Johansson, Lars and Kullberg, Joel},
	month = mar,
	year = {2015},
	pmid = {25665840},
	keywords = {Brain volume, Gender differences, Intracranial volume, Normalization, Sexual dimorphism},
	pages = {227--235},
}

@article{putnick_measurement_2016,
	title = {Measurement invariance conventions and reporting: {The} state of the art and future directions for psychological research},
	volume = {41},
	issn = {0273-2297},
	shorttitle = {Measurement invariance conventions and reporting},
	url = {https://www.sciencedirect.com/science/article/pii/S0273229716300351},
	doi = {10.1016/j.dr.2016.06.004},
	abstract = {Measurement invariance assesses the psychometric equivalence of a construct across groups or across time. Measurement noninvariance suggests that a construct has a different structure or meaning to different groups or on different measurement occasions in the same group, and so the construct cannot be meaningfully tested or construed across groups or across time. Hence, prior to testing mean differences across groups or measurement occasions (e.g., boys and girls, pretest and posttest), or differential relations of the construct across groups, it is essential to assess the invariance of the construct. Conventions and reporting on measurement invariance are still in flux, and researchers are often left with limited understanding and inconsistent advice. Measurement invariance is tested and established in different steps. This report surveys the state of measurement invariance testing and reporting, and details the results of a literature review of studies that tested invariance. Most tests of measurement invariance include configural, metric, and scalar steps; a residual invariance step is reported for fewer tests. Alternative fit indices (AFIs) are reported as model fit criteria for the vast majority of tests; χ2 is reported as the single index in a minority of invariance tests. Reporting AFIs is associated with higher levels of achieved invariance. Partial invariance is reported for about one-third of tests. In general, sample size, number of groups compared, and model size are unrelated to the level of invariance achieved. Implications for the future of measurement invariance testing, reporting, and best practices are discussed.},
	urldate = {2026-01-29},
	journal = {Developmental Review},
	author = {Putnick, Diane L. and Bornstein, Marc H.},
	month = sep,
	year = {2016},
	keywords = {Comparative psychology, Confirmatory factor analysis, Measurement invariance, Multiple-group analysis, Structural equation modeling},
	pages = {71--90},
	file = {ScienceDirect Full Text PDF:files/2947/Putnick and Bornstein - 2016 - Measurement invariance conventions and reporting The state of the art and future directions for psy.pdf:application/pdf;ScienceDirect Snapshot:files/2946/S0273229716300351.html:text/html},
}

